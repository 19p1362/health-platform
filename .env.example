# ──────────────────────────────────────────────
# HealthBridge Platform — Environment Variables
# ──────────────────────────────────────────────

# Application
SECRET_KEY=change-me-in-production-32-chars-min
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://healthbridge:healthbridge2025@localhost:5432/healthbridge
DATABASE_SYNC_URL=postgresql://healthbridge:healthbridge2025@localhost:5432/healthbridge

# Redis Cache
REDIS_URL=redis://:healthbridge-redis@localhost:6379/0

# ABHA (Ayushman Bharat Health Account)
ABHA_API_BASE_URL=https://sandbox.abdm.gov.in
ABHA_CLIENT_ID=your-abha-client-id
ABHA_CLIENT_SECRET=your-abha-client-secret
ABHA_CALLBACK_URL=http://localhost:8080/api/v1/abha/callback

# Aadhaar eKYC
AADHAAR_EKYC_ENABLED=true
AADHAAR_API_BASE_URL=https://sandbox.uidai.gov.in
AADHAAR_LICENSE_KEY=your-aadhaar-license-key
AADHAAR_ASA_ID=your-asa-id
AADHAAR_SUB_ASA_ID=your-sub-asa-id

# FHIR Server
FHIR_SERVER_BASE=http://localhost:8080/fhir

# Consent Manager
CONSENT_MANAGER_ENABLED=false
CONSENT_MANAGER_API_URL=https://consent-manager.example.com

# Encryption Master Key (Fernet 32-byte base64)
ENCRYPTION_KEY=base64:your-fernet-key-here

# Email (Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

# JWT
JWT_SECRET=change-me-in-production-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ── Document Ingestion ──
AI_EXTRACTION_API_URL=https://api.openai.com/v1/chat/completions
AI_EXTRACTION_API_KEY=                      # Set for AI-powered extraction (or use mock)
AI_EXTRACTION_MODEL=gpt-4o-mini
OCR_ENABLED=true

# ── WhatsApp Webhook (Meta Cloud API) ──
WHATSAPP_ACCESS_TOKEN=                      # Meta WhatsApp Cloud API permanent token
WHATSAPP_PHONE_NUMBER_ID=                   # Phone number ID from Meta Business Account
WHATSAPP_VERIFY_TOKEN=healthbridge-verify-2026  # Custom webhook verify token

# ── Twilio WhatsApp ──
TWILIO_WHATSAPP_NUMBER=+14155238886         # Twilio WhatsApp Sandbox number

# ═══════════════════════════════════════════════
# Phase 2 — Orchestrator Config (from healthcare-orchestra)
# ═══════════════════════════════════════════════
HEALTHBRIDGE_API_URL=http://localhost:8080
DB_PATH=
DASHBOARD_PORT=5000
DEBUG=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@healthbridge.local
