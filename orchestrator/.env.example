# Healthcare Orchestra — Environment Configuration
# Copy this to .env and fill in your values

# --- HealthBridge API ---
HEALTHBRIDGE_API_URL=http://localhost:8080

# --- SMTP Email (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Dashboard ---
DASHBOARD_PORT=5000

# --- Security ---
JWT_SECRET=orchestra-change-me-in-production
ENCRYPTION_KEY=
